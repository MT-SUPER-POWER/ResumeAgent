# ResumeAgent Docker Compose 环境变量
#
# 所有 RA_* 变量同时被 backend 容器和 postgres 容器读取，
# 数据库用户名、密码、库名在 docker-compose.yml 中统一引用此文件，保持单点配置。
#
# 如需脱离 Docker 单独启动后端（如 cargo run -- serve）：
#   cp .env ../repo/backend/.env
# 然后直接在 backend 目录运行即可，后端通过 dotenvy 自动加载 .env。
#
# 从 .env.example 生成，包含随机密钥

# api-key deepseek-v4-pro: sk-76e08074157a4a91b7cf65124b092f65
#

RA_VERSION=1.0.0

# ===== Database =====
RA_DB__HOST=postgres
RA_DB__PORT=5432
RA_DB__USERNAME=resume_agent
RA_DB__PASSWORD=changeme
RA_DB__DB_NAME=resume_agent
RA_DB__MAX_CONNECTIONS=20

# ===== Server =====
RA_SERVER__PORT=8080

# ===== Auth =====
RA_AUTH__JWT_SECRET=daa3188c2334c3bec9563e0c171641c5b85ca241afa9c70df7baacae426d1c0f
RA_AUTH__JWT_TTL_HOURS=168

# ===== Crypto =====
RA_CRYPTO__MASTER_KEY=4d23ba597a24b9a35854a094ffe2e9f96f591bfde3da4ba7b3885eaa7c5a551d

# ===== LLM =====
RA_LLM__DEFAULT_MODEL=deepseek-v4-flash
RA_LLM__MAX_RETRIES=3

# ===== Pipeline =====
RA_PIPELINE__PARSE_WORKERS=2
RA_PIPELINE__EVALUATE_WORKERS=3

# ===== Logger =====
RA_LOGGER__DIR=logs
RA_LOGGER__LEVEL=info

# ===== Output =====
RA_OUTPUT__BASE_DIR=./output
